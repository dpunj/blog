---
import { existsSync, readFileSync } from "node:fs";
import LibraryExplorer from "../components/library/LibraryExplorer";
import BaseLayout from "../layouts/BaseLayout.astro";
import type { LibraryData, TagHierarchyConfig } from "../lib/library";
import { buildTagHierarchy } from "../lib/library";

const pageTitle = "Library";
const pageDescription = "My digital garden of bookmarks, articles, and papers";

function readJsonFile<T>(url: URL, fallback: T): T {
	if (!existsSync(url)) return fallback;
	return JSON.parse(readFileSync(url, "utf-8")) as T;
}

// Load library data (exported from SQLite via `bun sync --export-library`).
// Fall back to an empty library so builds still pass before the first export.
const libraryData = readJsonFile<LibraryData>(
	new URL("../../public/data/library.json", import.meta.url),
	{ fetchedAt: new Date().toISOString(), resources: [] },
);
const tagHierarchyConfig = readJsonFile<TagHierarchyConfig>(
	new URL("../data/tag-hierarchy.json", import.meta.url),
	{ hierarchy: {} },
);
const resources = libraryData.resources;
const fetchedAt = libraryData.fetchedAt;
const hierarchy = buildTagHierarchy(tagHierarchyConfig, resources);
---

<BaseLayout pageTitle={pageTitle}>
	<h1 class="text-4xl font-bold mb-4">{pageTitle}</h1>
	<p class="text-gray-600 dark:text-gray-400 mb-8">{pageDescription}</p>

	<LibraryExplorer
		resources={resources}
		hierarchy={hierarchy}
		fetchedAt={fetchedAt}
		client:load
	/>
</BaseLayout>
